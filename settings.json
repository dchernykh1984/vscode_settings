{
  "workbench.startupEditor": "none",
  "claudeCode.preferredLocation": "panel",
  "workbench.sideBar.location": "left",

  "ruff.configuration": "${workspaceFolder}/pyproject.toml",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[plaintext]": {
    "editor.formatOnSave": false
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "gitlens.remotes": [{ "domain": "github.com", "type": "GitHub" }],

  "files.associations": {
    "**/CODEOWNERS": "plaintext",
    "**/.gitlab/CODEOWNERS": "plaintext",
    "**/.github/CODEOWNERS": "plaintext",
    "**/.continue/*.yaml": "yaml",
    "**/.continue/*.yml": "yaml"
  },
  "git.confirmSync": false,
  "git.ignoreRebaseWarning": true,
  "gitlens.blame.compact": false,
  "gitlens.blame.avatars": false,

  "gitlens.blame.dateFormat": "DD.MM.YY",
  "gitlens.blame.format": "${agoOrDate|8} ${author|10-}",

  "gitlens.blame.fontWeight": "normal",
  "gitlens.blame.fontStyle": "normal",

  "gitlens.blame.heatmap.enabled": false,
  "gitlens.blame.separateLines": true,
  "gitlens.blame.fontSize": 10.5,
  "diffEditor.ignoreTrimWhitespace": false,
  "git.autofetch": true,
  "python.terminal.activateEnvironment": true
}
